---
// Re-export types from shared types module
export type { StatsData, StatsState } from '../types/api';
import { API_BASE } from '../lib/api';
---

<div id="stats-container" data-api-base={API_BASE}>
  <!-- Accessibility: Screen reader announcements -->
  <div aria-live="polite" aria-atomic="true" class="sr-only" id="stats-status"></div>

  <!-- Summary Cards Grid -->
  <div class="stats-summary-cards">
    <div class="stats-card loading">
      <div class="stats-number skeleton"></div>
      <div class="stats-label">Total Links</div>
    </div>
    <div class="stats-card loading">
      <div class="stats-number skeleton"></div>
      <div class="stats-label">Total Tags</div>
    </div>
    <div class="stats-card loading">
      <div class="stats-number skeleton"></div>
      <div class="stats-label">Total Views</div>
    </div>
  </div>

  <!-- Stats Lists -->
  <div class="stats-lists">
    <section class="stats-section">
      <h2>Top Tags</h2>
      <div class="stats-list loading">
        <div class="skeleton-item"></div>
        <div class="skeleton-item"></div>
        <div class="skeleton-item"></div>
      </div>
    </section>

    <section class="stats-section">
      <h2>Most Viewed</h2>
      <div class="stats-list loading">
        <div class="skeleton-item"></div>
        <div class="skeleton-item"></div>
        <div class="skeleton-item"></div>
      </div>
    </section>
  </div>

  <!-- Refresh Button -->
  <div class="stats-actions">
    <button id="refresh-stats" class="stats-refresh-btn">Refresh Statistics</button>
  </div>
</div>

<script type="module">
  import { StatsController } from '../lib/statsController.js';

  // Initialize when DOM is ready
  let statsController: StatsController;

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      statsController = new StatsController();
    });
  } else {
    statsController = new StatsController();
  }

  // refreshStats is available on the statsController instance for debugging
  // Access via browser console: statsController.refreshStats()
</script>

<style>
  /* Stats Container */
  #stats-container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* Summary Cards Grid */
  .stats-summary-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .stats-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-lg);
    text-align: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .stats-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  .stats-number {
    font-size: 2.5rem;
    font-weight: 600;
    color: var(--color-primary);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .stats-label {
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.8;
  }

  /* Stats Lists Layout */
  .stats-lists {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }

  .stats-section h2 {
    color: var(--color-primary);
    margin-bottom: var(--space-md);
    font-size: 1.25rem;
  }

  .stats-list {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-lg);
  }

  /* Loading States */
  .skeleton {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: loading 1.5s infinite;
    border-radius: 4px;
    height: 2.5rem;
    width: 60%;
    margin: 0 auto;
  }

  .skeleton-item {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: loading 1.5s infinite;
    border-radius: 4px;
    height: 1.5rem;
    margin-bottom: var(--space-sm);
  }

  .skeleton-item:nth-child(1) { width: 80%; }
  .skeleton-item:nth-child(2) { width: 65%; }
  .skeleton-item:nth-child(3) { width: 75%; }

  @keyframes loading {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  /* Responsive Design */
  @media (max-width: 767px) {
    .stats-summary-cards {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .stats-lists {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .stats-card {
      padding: var(--space-md);
    }

    .stats-number {
      font-size: 2rem;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .stats-summary-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Ranked Lists */
  .ranked-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .ranked-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm);
    background-color: var(--color-bg);
    border-radius: 4px;
    transition: background-color 0.2s ease;
  }

  .ranked-item:hover {
    background-color: var(--color-footer);
  }

  .ranked-item .rank {
    font-weight: 600;
    color: var(--color-primary);
    min-width: 1.5rem;
    text-align: center;
  }

  .ranked-item .name {
    flex: 1;
    font-weight: 500;
  }

  .ranked-item .name a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .ranked-item .name a:hover {
    text-decoration: underline;
  }

  .ranked-item .count {
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.8;
    white-space: nowrap;
  }

  /* Error and Empty States */
  .error-message {
    text-align: center;
    padding: var(--space-lg);
  }

  .error-message p {
    color: var(--color-text);
    margin-bottom: var(--space-md);
    opacity: 0.8;
  }

  .empty-message {
    text-align: center;
    color: var(--color-text);
    opacity: 0.8;
    padding: var(--space-lg);
    font-style: italic;
  }

  /* Refresh Button */
  .stats-actions {
    margin-top: var(--space-xl);
    text-align: center;
  }

  .stats-refresh-btn,
  .retry-btn {
    background-color: var(--color-primary);
    color: var(--color-bg);
    border: none;
    border-radius: 4px;
    padding: var(--space-sm) var(--space-lg);
    font-family: var(--font-body);
    font-size: 0.875rem;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.1s ease;
  }

  .stats-refresh-btn:hover,
  .retry-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .stats-refresh-btn:active,
  .retry-btn:active {
    transform: translateY(0);
  }

  .stats-refresh-btn:focus,
  .retry-btn:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .stats-refresh-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  /* Loading indicator for button */
  .stats-refresh-btn.loading {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .stats-refresh-btn.loading::after {
    content: '...';
    animation: dots 1.5s infinite;
  }

  @keyframes dots {
    0%, 33% { content: '...'; }
    66% { content: '..'; }
    100% { content: '.'; }
  }

  /* Screen reader only content */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>