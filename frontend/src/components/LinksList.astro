---
// Import the LinkItem interface and LinkCard component
import LinkCard, { type LinkItem } from './LinkCard.astro';

// Component interface
interface Props {
  links: LinkItem[];
  totalCount: number;
  searchQuery?: string;
  isSearchResult?: boolean;
  className?: string;
}

const {
  links,
  totalCount,
  searchQuery = '',
  isSearchResult = false,
  className = ''
} = Astro.props;

// Determine display states
const hasLinks = links && links.length > 0;
const isEmpty = !hasLinks;

// Generate context messages for different scenarios
function getResultsHeader(): { title: string; subtitle: string } {
  if (isEmpty && isSearchResult) {
    return {
      title: `No results for "${searchQuery}"`,
      subtitle: 'Try adjusting your search terms or browse all links below.'
    };
  }

  if (isEmpty && !isSearchResult) {
    return {
      title: 'No links available',
      subtitle: 'Links will appear here as they are added to the system.'
    };
  }

  if (isSearchResult) {
    return {
      title: `Search Results for "${searchQuery}"`,
      subtitle: `Found ${totalCount} ${totalCount === 1 ? 'link' : 'links'} matching your query`
    };
  }

  return {
    title: 'All Links',
    subtitle: `${totalCount} ${totalCount === 1 ? 'link' : 'links'} available`
  };
}

const { title, subtitle } = getResultsHeader();
---

<div class={`links-list ${className}`}>
  <!-- Results header with context -->
  <header class="links-list-header">
    <h1 class="links-list-title">{title}</h1>
    <p class="links-list-subtitle">{subtitle}</p>
  </header>

  <!-- Empty state -->
  {isEmpty && (
    <div class="empty-state">
      <div class="empty-icon">
        {isSearchResult ? '🔍' : '📋'}
      </div>
      <div class="empty-content">
        <h2 class="empty-title">
          {isSearchResult ? 'No matching links found' : 'No links yet'}
        </h2>
        <p class="empty-message">
          {isSearchResult
            ? `Your search for "${searchQuery}" didn't match any links. Try different keywords or check your spelling.`
            : 'Links will appear here once they are added to your collection.'
          }
        </p>
        {isSearchResult && (
          <div class="empty-actions">
            <button
              onclick="document.querySelector('input[name=\\\"q\\\"]')?.focus(); document.querySelector('input[name=\\\"q\\\"]').value = ''"
              class="clear-search-btn"
              type="button"
            >
              Clear Search
            </button>
          </div>
        )}
      </div>
    </div>
  )}

  <!-- Links grid -->
  {hasLinks && (
    <div class="links-grid" aria-label={`${totalCount} links displayed`}>
      {links.map((link, index) => (
        <LinkCard
          link={link}
          showIndex={isSearchResult ? undefined : index + 1}
          key={link.id}
        />
      ))}
    </div>
  )}

  <!-- Results footer (for pagination info in future) -->
  {hasLinks && totalCount > links.length && (
    <footer class="links-list-footer">
      <p class="pagination-hint">
        Showing {links.length} of {totalCount} links
      </p>
    </footer>
  )}
</div>

<style>
  /* Main container */
  .links-list {
    width: 100%;
  }

  /* Header section */
  .links-list-header {
    text-align: center;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .links-list-title {
    font-size: 2.25rem;
    margin-bottom: var(--space-sm);
    color: var(--color-primary);
    font-weight: 700;
    line-height: 1.2;
  }

  .links-list-subtitle {
    font-size: 1.125rem;
    color: var(--color-text);
    opacity: 0.8;
    margin: 0;
    line-height: 1.4;
  }

  /* Empty state styles */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 40vh;
    padding: var(--space-xl);
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: var(--space-lg);
    opacity: 0.6;
    line-height: 1;
  }

  .empty-content {
    max-width: 500px;
  }

  .empty-title {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
    color: var(--color-primary);
    font-weight: 600;
  }

  .empty-message {
    font-size: 1rem;
    color: var(--color-text);
    opacity: 0.8;
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .empty-actions {
    display: flex;
    justify-content: center;
  }

  .clear-search-btn {
    color: var(--color-primary);
    background-color: transparent;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: var(--space-sm) var(--space-lg);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .clear-search-btn:hover {
    background-color: var(--color-footer);
    border-color: var(--color-primary);
  }

  .clear-search-btn:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .clear-search-btn:active {
    transform: translateY(1px);
  }

  /* Links grid - matching tag page pattern */
  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  /* Footer section */
  .links-list-footer {
    text-align: center;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .pagination-hint {
    color: var(--color-text);
    opacity: 0.7;
    font-size: 0.9rem;
    margin: 0;
  }

  /* Responsive design */
  @media (max-width: 767px) {
    .links-list-header {
      margin-bottom: var(--space-lg);
      padding-bottom: var(--space-md);
    }

    .links-list-title {
      font-size: 1.75rem;
    }

    .links-list-subtitle {
      font-size: 1rem;
    }

    .empty-state {
      min-height: 30vh;
      padding: var(--space-lg);
    }

    .empty-icon {
      font-size: 3rem;
    }

    .empty-title {
      font-size: 1.5rem;
    }

    .empty-message {
      font-size: 1rem;
    }

    .links-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .clear-search-btn {
      width: 100%;
      max-width: 200px;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .links-grid {
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .links-list-header,
    .links-list-footer {
      border-width: 2px;
    }

    .clear-search-btn {
      border-width: 2px;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .clear-search-btn {
      transition: none;
    }

    .clear-search-btn:active {
      transform: none;
    }
  }

  /* Focus management for accessibility */
  .links-grid:focus-within {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* Ensure proper spacing between header and grid */
  .links-list-header + .links-grid {
    margin-top: 0;
  }

  /* Loading state preparation (for future client-side updates) */
  .links-grid[data-loading="true"] {
    opacity: 0.6;
    pointer-events: none;
  }
</style>