---
// Import LinkItem interface for prop typing
import { type LinkItem } from './LinkCard.astro';

// Component interface
interface Props {
  initialQuery?: string;
  initialResults?: LinkItem[];
  initialCount?: number;
  className?: string;
}

const {
  initialQuery = '',
  initialResults = [],
  initialCount = 0,
  className = ''
} = Astro.props;

// Format query for display
const displayQuery = initialQuery ? decodeURIComponent(initialQuery) : '';
---

<div class={`search-interface ${className}`}>
  <!-- Search form with accessibility -->
  <form
    class="search-form"
    method="GET"
    action="/"
    role="search"
    aria-label="Search links"
  >
    <div class="search-input-container">
      <label for="search-input" class="search-label">
        Search Links
      </label>
      <div class="search-input-wrapper">
        <input
          id="search-input"
          name="q"
          type="search"
          class="search-input"
          placeholder="Search by title, description, or tag..."
          value={displayQuery}
          autocomplete="off"
          aria-describedby="search-help"
        />
        <button
          type="submit"
          class="search-button"
          aria-label="Search"
          title="Search links"
        >
          <span class="search-icon" aria-hidden="true">🔍</span>
        </button>
        {initialQuery && (
          <button
            type="button"
            class="clear-button"
            aria-label="Clear search"
            title="Clear search"
            onclick="window.location.href = '/'"
          >
            <span class="clear-icon" aria-hidden="true">✕</span>
          </button>
        )}
      </div>
      <div id="search-help" class="search-help">
        Search across titles, descriptions, and tags to find relevant links
      </div>
    </div>
  </form>

  <!-- Loading indicator (hidden initially) -->
  <div class="loading-indicator" aria-live="polite" aria-hidden="true">
    <div class="loading-spinner" aria-hidden="true"></div>
    <span class="loading-text">Searching...</span>
  </div>

  <!-- Error display area (hidden initially) -->
  <div class="error-display" role="alert" aria-live="assertive" aria-hidden="true">
    <div class="error-content">
      <div class="error-icon" aria-hidden="true">⚠️</div>
      <div class="error-message">
        <strong class="error-title">Search Failed</strong>
        <p class="error-text">Unable to complete search. Please try again.</p>
      </div>
      <button type="button" class="error-retry" aria-label="Retry search">
        Retry
      </button>
    </div>
  </div>

  <!-- Results count display -->
  <div class="results-meta" aria-live="polite">
    {initialQuery && (
      <div class="results-summary">
        <span class="results-count">
          {initialCount === 0
            ? 'No results found'
            : `${initialCount} ${initialCount === 1 ? 'result' : 'results'} found`}
        </span>
        {initialQuery && (
          <span class="results-query">
            for "<strong>{displayQuery}</strong>"
          </span>
        )}
      </div>
    )}
  </div>
</div>

<style>
  /* Main container */
  .search-interface {
    width: 100%;
    margin-bottom: var(--space-xl);
  }

  /* Search form */
  .search-form {
    width: 100%;
    margin-bottom: var(--space-md);
  }

  .search-input-container {
    width: 100%;
  }

  .search-label {
    display: block;
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: stretch;
    width: 100%;
    border-radius: 8px;
    border: 2px solid var(--color-border);
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .search-input-wrapper:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(0, 116, 204, 0.1);
  }

  .search-input {
    flex: 1;
    padding: var(--space-md);
    border: none;
    background-color: var(--color-bg);
    color: var(--color-text);
    font-size: 1rem;
    font-family: var(--font-body);
    outline: none;
  }

  .search-input::placeholder {
    color: var(--color-text);
    opacity: 0.6;
  }

  .search-button,
  .clear-button {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-md);
    border: none;
    background-color: var(--color-primary);
    color: var(--color-bg);
    cursor: pointer;
    font-size: 1rem;
    transition: background-color 0.2s ease;
    min-width: 48px;
  }

  .search-button:hover {
    background-color: #005a9d;
  }

  .search-button:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .clear-button {
    background-color: var(--color-text);
    border-left: 1px solid var(--color-border);
  }

  .clear-button:hover {
    background-color: #666;
  }

  .search-icon,
  .clear-icon {
    line-height: 1;
  }

  .search-help {
    margin-top: var(--space-xs);
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.7;
    line-height: 1.4;
  }

  /* Loading indicator */
  .loading-indicator {
    display: none;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background-color: var(--color-footer);
    border-radius: 8px;
    margin-bottom: var(--space-md);
  }

  .loading-indicator[aria-hidden="false"] {
    display: flex;
  }

  .loading-spinner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--color-border);
    border-top: 2px solid var(--color-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  .loading-text {
    font-size: 0.9rem;
    color: var(--color-text);
    font-weight: 500;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* Error display */
  .error-display {
    display: none;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    padding: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .error-display[aria-hidden="false"] {
    display: block;
  }

  .error-content {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .error-icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .error-message {
    flex: 1;
  }

  .error-title {
    display: block;
    font-weight: 600;
    color: #dc2626;
    margin-bottom: var(--space-xs);
  }

  .error-text {
    margin: 0;
    color: #374151;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .error-retry {
    background-color: #dc2626;
    color: white;
    border: none;
    border-radius: 4px;
    padding: var(--space-xs) var(--space-sm);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s ease;
    flex-shrink: 0;
  }

  .error-retry:hover {
    background-color: #b91c1c;
  }

  .error-retry:focus {
    outline: 2px solid #dc2626;
    outline-offset: 2px;
  }

  /* Results metadata */
  .results-meta {
    margin-bottom: var(--space-lg);
  }

  .results-summary {
    text-align: center;
    padding: var(--space-sm);
    background-color: var(--color-footer);
    border-radius: 4px;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .results-count {
    font-weight: 500;
  }

  .results-query {
    margin-left: var(--space-xs);
  }

  /* Responsive design */
  @media (max-width: 767px) {
    .search-label {
      font-size: 1rem;
    }

    .search-input {
      font-size: 16px; /* Prevent iOS zoom */
      padding: var(--space-sm);
    }

    .search-button,
    .clear-button {
      padding: var(--space-sm);
      min-width: 44px;
    }

    .search-help {
      font-size: 0.8rem;
    }

    .error-content {
      flex-direction: column;
      gap: var(--space-sm);
    }

    .error-retry {
      align-self: flex-start;
    }
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .search-input-wrapper {
      border-width: 3px;
    }

    .search-button,
    .clear-button {
      border: 2px solid var(--color-text);
    }

    .loading-indicator,
    .error-display,
    .results-summary {
      border: 2px solid var(--color-border);
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .search-input-wrapper {
      transition: none;
    }

    .search-button,
    .clear-button,
    .error-retry {
      transition: none;
    }

    .loading-spinner {
      animation: none;
      border-top-color: var(--color-border);
    }
  }

  /* Focus management for keyboard navigation */
  .search-input:focus {
    outline: none;
  }

  /* Ensure proper spacing in search interface */
  .search-interface + * {
    margin-top: var(--space-lg);
  }

  /* State classes for JavaScript interaction (prepared for Step 4) */
  .search-interface[data-loading="true"] .loading-indicator {
    display: flex;
  }

  .search-interface[data-error="true"] .error-display {
    display: block;
  }

  .search-interface[data-searching="true"] .search-input {
    opacity: 0.7;
  }
</style>

<script>
  // Client-side search enhancement with progressive enhancement
  interface LinkItem {
    id: string;
    title: string;
    url: string;
    description: string;
    tags: string[];
    created_at: string;
    view_count: number;
  }

  interface SearchResponse {
    links: LinkItem[];
    page: number;
    per_page: number;
    total_count: number;
    total_pages: number;
  }

  interface SearchState {
    query: string;
    isLoading: boolean;
    results: LinkItem[];
    totalCount: number;
    error: string | null;
  }

  // Initialize only if JavaScript is enabled and we have the necessary elements
  document.addEventListener('DOMContentLoaded', () => {
    const searchInterface = document.querySelector('.search-interface');
    const searchForm = document.querySelector('.search-form') as HTMLFormElement;
    const searchInput = document.querySelector('.search-input') as HTMLInputElement;
    const loadingIndicator = document.querySelector('.loading-indicator');
    const errorDisplay = document.querySelector('.error-display');
    const linksListContainer = document.querySelector('.home-links-list .links-list');

    if (!searchInterface || !searchForm || !searchInput || !loadingIndicator || !errorDisplay) {
      console.log('Search interface elements not found, using server-side fallback');
      return;
    }

    // API configuration
    const API_BASE = (window as any).PUBLIC_API_URL || 'http://localhost:8090';
    const DEBOUNCE_DELAY = 300;
    const FETCH_TIMEOUT = 5000;

    // State management
    let state: SearchState = {
      query: searchInput.value || '',
      isLoading: false,
      results: [],
      totalCount: 0,
      error: null
    };

    let debounceTimeout: number | null = null;
    let currentController: AbortController | null = null;

    // Prevent default form submission and handle with JavaScript
    searchForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const formData = new FormData(searchForm);
      const query = formData.get('q') as string || '';
      performSearch(query);
    });

    // Debounced input handling
    searchInput.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      const query = target.value.trim();

      // Clear existing debounce
      if (debounceTimeout) {
        clearTimeout(debounceTimeout);
      }

      // Set new debounce
      debounceTimeout = setTimeout(() => {
        if (query !== state.query) {
          performSearch(query);
        }
      }, DEBOUNCE_DELAY) as unknown as number;
    });

    // Search function with error handling and loading states
    async function performSearch(query: string): Promise<void> {
      // Cancel any existing request
      if (currentController) {
        currentController.abort();
      }

      // Update state
      state.query = query;
      state.isLoading = true;
      state.error = null;

      // Update UI to show loading
      updateLoadingState(true);
      updateErrorState(false);

      // If empty query, redirect to home page (server-side will handle)
      if (!query.trim()) {
        window.history.pushState({}, '', '/');
        window.location.reload();
        return;
      }

      try {
        currentController = new AbortController();
        const timeoutId = setTimeout(() => currentController?.abort(), FETCH_TIMEOUT);

        const response = await fetch(`${API_BASE}/api/links/search?q=${encodeURIComponent(query)}`, {
          signal: currentController.signal,
          headers: { 'Accept': 'application/json' }
        });

        clearTimeout(timeoutId);

        if (response.ok) {
          const searchData: SearchResponse = await response.json();
          state.results = searchData.links || [];
          state.totalCount = searchData.total_count || 0;
          state.isLoading = false;

          // Update URL without page reload
          const url = new URL(window.location.href);
          url.searchParams.set('q', query);
          window.history.pushState({ query }, '', url.toString());

          // Update DOM with results
          updateResultsDOM(state.results, state.totalCount, query);
          updateLoadingState(false);

          // Announce to screen readers
          announceToScreenReader(`Found ${state.totalCount} results for ${query}`);

        } else {
          throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }

      } catch (err) {
        state.isLoading = false;

        if (err && typeof err === 'object' && 'name' in err && err.name === 'AbortError') {
          // Request was cancelled, don't show error
          return;
        }

        state.error = err instanceof Error ? err.message : 'Search failed';
        updateLoadingState(false);
        updateErrorState(true, state.error);

        // Announce error to screen readers
        announceToScreenReader('Search failed. Please try again.');
      }
    }

    // Update loading state UI
    function updateLoadingState(isLoading: boolean): void {
      if (isLoading) {
        loadingIndicator?.setAttribute('aria-hidden', 'false');
        searchInterface?.setAttribute('data-loading', 'true');
      } else {
        loadingIndicator?.setAttribute('aria-hidden', 'true');
        searchInterface?.removeAttribute('data-loading');
      }
    }

    // Update error state UI
    function updateErrorState(hasError: boolean, errorMessage?: string): void {
      if (hasError && errorMessage) {
        errorDisplay?.setAttribute('aria-hidden', 'false');
        const errorText = errorDisplay?.querySelector('.error-text');
        if (errorText) {
          errorText.textContent = errorMessage;
        }
      } else {
        errorDisplay?.setAttribute('aria-hidden', 'true');
      }
    }

    // Update results in DOM
    function updateResultsDOM(results: LinkItem[], totalCount: number, query: string): void {
      // Find the LinksList component and update it
      const linksListElement = document.querySelector('.links-list');
      const linksListHeader = document.querySelector('.links-list-header');
      const linksGrid = document.querySelector('.links-grid');

      if (!linksListElement || !linksListHeader || !linksGrid) {
        // Fallback: reload page with search parameters if DOM structure not as expected
        window.location.reload();
        return;
      }

      // Update header
      const titleElement = linksListHeader.querySelector('.links-list-title');
      const subtitleElement = linksListHeader.querySelector('.links-list-subtitle');

      if (titleElement && subtitleElement) {
        titleElement.textContent = `Search Results for "${query}"`;
        subtitleElement.textContent = `Found ${totalCount} ${totalCount === 1 ? 'link' : 'links'} matching your query`;
      }

      // If no results, show empty state
      if (results.length === 0) {
        linksGrid.innerHTML = `
          <div class="empty-state">
            <div class="empty-icon">🔍</div>
            <div class="empty-content">
              <h2 class="empty-title">No matching links found</h2>
              <p class="empty-message">Your search for "${query}" didn't match any links. Try different keywords or check your spelling.</p>
              <div class="empty-actions">
                <button onclick="document.querySelector('.search-input')?.focus(); document.querySelector('.search-input').value = ''" class="clear-search-btn" type="button">
                  Clear Search
                </button>
              </div>
            </div>
          </div>
        `;
      } else {
        // Update with new results (simplified version - in real app you'd use a templating system)
        // For now, trigger a page reload with the search parameters to get server-side rendering
        // This ensures consistency with server-rendered components
        const url = new URL(window.location.href);
        url.searchParams.set('q', query);
        window.location.href = url.toString();
      }
    }

    // Announce to screen readers
    function announceToScreenReader(message: string): void {
      const announcement = document.createElement('div');
      announcement.setAttribute('aria-live', 'assertive');
      announcement.setAttribute('aria-atomic', 'true');
      announcement.style.position = 'absolute';
      announcement.style.left = '-10000px';
      announcement.style.width = '1px';
      announcement.style.height = '1px';
      announcement.style.overflow = 'hidden';
      announcement.textContent = message;

      document.body.appendChild(announcement);

      setTimeout(() => {
        document.body.removeChild(announcement);
      }, 1000);
    }

    // Handle browser back/forward buttons
    window.addEventListener('popstate', (event) => {
      const url = new URL(window.location.href);
      const query = url.searchParams.get('q') || '';
      searchInput.value = query;

      if (event.state && event.state.query !== undefined) {
        // We have state, so this was a programmatic navigation
        if (!event.state.query) {
          window.location.reload(); // Go back to server-rendered home page
        }
      } else {
        // Browser navigation, reload to ensure consistency
        window.location.reload();
      }
    });

    // Error retry functionality
    const retryButton = errorDisplay?.querySelector('.error-retry');
    retryButton?.addEventListener('click', () => {
      performSearch(state.query);
    });

    console.log('Client-side search enhancement loaded');
  });
</script>