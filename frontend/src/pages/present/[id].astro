---
// Disable prerendering for SSR
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import PresenterController from '../../components/PresenterController.astro';
import { API_BASE, FETCH_TIMEOUT_LONG, apiFetch, ApiError } from '../../lib/api';

// Get session ID from URL parameters
const { id } = Astro.params;

// Get admin token from query string
const token = Astro.url.searchParams.get('token');

// Basic validation
if (!id) {
  return Astro.redirect('/404');
}

const FETCH_TIMEOUT = FETCH_TIMEOUT_LONG; // Use longer timeout for complex operations

// Session data and error state
let session = null;
let presentation = null;
let error = null;

try {
  // First, fetch session data
  const sessionData = await apiFetch(`${API_BASE}/api/collections/sync_sessions/records/${id}`, {
    headers: {
      'Accept': 'application/json',
      'Authorization': Astro.request.headers.get('Authorization') || '',
      'Cookie': Astro.request.headers.get('Cookie') || ''
    },
    timeout: FETCH_TIMEOUT
  });

    // If token provided, validate it
    if (token) {
      // Validate admin token (server-side comparison)
      if (sessionData.admin_token !== token) {
        error = 'invalid_token';
      } else {
        session = sessionData;
      }
    } else {
      // Check if user owns this session (no token provided)
      // This would require authentication context
      session = sessionData;
    }

    // If we have a valid session, fetch the associated presentation
    if (session && session.presentation_id) {
      try {
        presentation = await apiFetch(
          `${API_BASE}/api/collections/presentations/records/${session.presentation_id}`,
          {
            headers: {
              'Accept': 'application/json',
              'Authorization': Astro.request.headers.get('Authorization') || '',
              'Cookie': Astro.request.headers.get('Cookie') || ''
            },
            timeout: FETCH_TIMEOUT
          }
        );
      } catch (presentationError) {
        console.warn('Error fetching presentation data:', presentationError);
        // Continue without presentation data - we can still control the session
      }
    }

} catch (fetchError) {
  if (fetchError instanceof ApiError) {
    if (fetchError.code === 'timeout') {
      error = 'timeout';
    } else if (fetchError.code === 'notfound' || fetchError.status === 404) {
      error = 'session_not_found';
    } else if (fetchError.status === 401) {
      error = 'authentication_required';
    } else if (fetchError.status === 403) {
      error = 'access_denied';
    } else {
      error = 'server_error';
    }
  } else {
    error = 'network_error';
    console.error('Network error:', fetchError);
  }
}

// Handle missing token for authenticated sessions
if (!error && session && !token) {
  error = 'missing_token';
}

// Error messages
const errorMessages = {
  missing_token: {
    title: 'Missing Admin Token',
    message: 'Admin token is required to control this presentation. Please check your URL and try again.',
    action: 'Return to Dashboard',
    actionUrl: '/present'
  },
  invalid_token: {
    title: 'Access Denied',
    message: 'Invalid admin token. You do not have permission to control this presentation.',
    action: 'Return to Dashboard',
    actionUrl: '/present'
  },
  session_not_found: {
    title: 'Session Not Found',
    message: 'This presentation session does not exist or has been removed.',
    action: 'Return to Dashboard',
    actionUrl: '/present'
  },
  authentication_required: {
    title: 'Authentication Required',
    message: 'You must be logged in to access presentation controls.',
    action: 'Log In',
    actionUrl: '/login'
  },
  access_denied: {
    title: 'Access Denied',
    message: 'You do not have permission to access this presentation.',
    action: 'Return to Dashboard',
    actionUrl: '/present'
  },
  network_error: {
    title: 'Connection Error',
    message: 'Unable to connect to the server. Please check your connection and try again.',
    action: 'Retry',
    actionUrl: ''
  },
  server_error: {
    title: 'Server Error',
    message: 'Something went wrong on our end. Please try again later.',
    action: 'Retry',
    actionUrl: ''
  },
  timeout: {
    title: 'Request Timeout',
    message: 'The request took too long. Please try again.',
    action: 'Retry',
    actionUrl: ''
  }
};

// Prepare presentation data for the controller
let presentationData = null;
if (session && presentation) {
  // Calculate current step from progress
  const currentStep = Math.round(session.progress * (presentation.step_count - 1));

  presentationData = {
    id: presentation.id,
    name: presentation.name,
    step_count: presentation.step_count,
    step_labels: presentation.step_labels || [],
    current_step: currentStep,
    progress: session.progress
  };
} else if (session) {
  // Fallback: create minimal presentation data from session
  presentationData = {
    id: session.presentation_id || 'unknown',
    name: 'Presentation',
    step_count: 5, // Default step count
    step_labels: [],
    current_step: Math.round(session.progress * 4), // Assumes 5 steps
    progress: session.progress
  };
}

const pageTitle = session ? `Presenter Control - ${presentationData?.name || 'Session ' + id}` :
                  error ? 'Error' : 'Loading...';
const description = session ? `Control your live presentation: ${presentationData?.name}` :
                    'Presenter control interface';
---

<BaseLayout title={pageTitle} description={description}>
  <div class="presenter-control-page">
    <div class="control-container">
      {error ? (
        <div class="error-container">
          <div class="error-content">
            <div class="error-icon" aria-hidden="true">⚠️</div>
            <div class="error-text">
              <h1 class="error-title">{errorMessages[error].title}</h1>
              <p class="error-message">{errorMessages[error].message}</p>
            </div>
          </div>
          <div class="error-actions">
            {errorMessages[error].actionUrl ? (
              <a href={errorMessages[error].actionUrl} class="error-action primary">
                {errorMessages[error].action}
              </a>
            ) : (
              <button type="button" class="error-action primary" onclick="window.location.reload()">
                {errorMessages[error].action}
              </button>
            )}
            <a href="/present" class="error-action secondary">
              Return to Dashboard
            </a>
          </div>
        </div>
      ) : session && presentationData ? (
        <>
          <header class="page-header">
            <div class="header-content">
              <h1 class="page-title">Presentation Control</h1>
              <div class="session-meta">
                <div class="meta-item">
                  <span class="meta-label">Session:</span>
                  <code class="meta-value">{session.id}</code>
                </div>
                <div class="meta-item">
                  <span class="meta-label">Status:</span>
                  <span class="status-badge live">
                    <span class="status-dot" aria-hidden="true"></span>
                    Live
                  </span>
                </div>
              </div>
            </div>
          </header>

          <PresenterController
            sessionId={id}
            adminToken={token || ''}
            presentationData={presentationData}
            className="main-controller"
          />
        </>
      ) : (
        <div class="loading-container">
          <div class="loading-content">
            <div class="loading-spinner" aria-hidden="true"></div>
            <h1 class="loading-title">Loading Presentation...</h1>
            <p class="loading-message">Please wait while we prepare your control interface.</p>
          </div>
        </div>
      )}
    </div>
  </div>

  {session && presentationData && (
    <div
      id="presenter-data-container"
      data-session-id={id}
      data-admin-token={token || ''}
      data-presentation-data={JSON.stringify(presentationData)}
      data-api-base={API_BASE}
      style="display: none;"
    ></div>
  )}
</BaseLayout>

<style>
  .presenter-control-page {
    min-height: 100vh;
    background-color: var(--color-bg);
    padding: var(--space-lg) 0;
  }

  .control-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  /* Page Header */
  .page-header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 2px solid var(--color-border);
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }

  .page-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.2;
  }

  .session-meta {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.9rem;
  }

  .meta-label {
    font-weight: 500;
    color: var(--color-text);
    opacity: 0.8;
  }

  .meta-value {
    background-color: var(--color-footer);
    padding: var(--space-xs) var(--space-sm);
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--color-text);
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .status-badge.live {
    background-color: #dcfce7;
    color: #166534;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-badge.live .status-dot {
    background-color: #22c55e;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* Error Container */
  .error-container {
    max-width: 600px;
    margin: var(--space-xl) auto;
    padding: var(--space-xl);
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 12px;
    text-align: center;
  }

  .error-content {
    display: flex;
    align-items: flex-start;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
    text-align: left;
  }

  .error-icon {
    font-size: 3rem;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .error-text {
    flex: 1;
  }

  .error-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #dc2626;
    margin: 0 0 var(--space-sm) 0;
    line-height: 1.3;
  }

  .error-message {
    color: #dc2626;
    margin: 0;
    line-height: 1.5;
    opacity: 0.9;
  }

  .error-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .error-action {
    display: inline-flex;
    align-items: center;
    padding: var(--space-sm) var(--space-lg);
    border-radius: 6px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
    font-size: 0.9rem;
    font-family: var(--font-body);
  }

  .error-action.primary {
    background-color: #dc2626;
    color: white;
  }

  .error-action.primary:hover {
    background-color: #b91c1c;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(220, 38, 38, 0.3);
  }

  .error-action.secondary {
    background-color: transparent;
    color: #dc2626;
    border: 1px solid #dc2626;
  }

  .error-action.secondary:hover {
    background-color: #dc2626;
    color: white;
    text-decoration: none;
  }

  .error-action:focus {
    outline: 2px solid #dc2626;
    outline-offset: 2px;
  }

  /* Loading Container */
  .loading-container {
    max-width: 600px;
    margin: var(--space-xl) auto;
    padding: var(--space-xl);
    text-align: center;
  }

  .loading-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .loading-spinner {
    width: 48px;
    height: 48px;
    border: 4px solid var(--color-border);
    border-top: 4px solid var(--color-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  .loading-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0;
  }

  .loading-message {
    color: var(--color-text);
    opacity: 0.8;
    margin: 0;
    line-height: 1.5;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* Main Controller Styling */
  .main-controller {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .control-container {
      padding: 0 var(--space-md);
    }

    .page-title {
      font-size: 1.75rem;
    }

    .header-content {
      flex-direction: column;
      align-items: stretch;
    }

    .session-meta {
      justify-content: space-between;
    }

    .error-content {
      flex-direction: column;
      text-align: center;
      gap: var(--space-md);
    }

    .error-actions {
      flex-direction: column;
    }

    .error-action {
      justify-content: center;
    }

    .loading-spinner {
      width: 40px;
      height: 40px;
      border-width: 3px;
    }
  }

  @media (max-width: 480px) {
    .presenter-control-page {
      padding: var(--space-md) 0;
    }

    .page-title {
      font-size: 1.5rem;
    }

    .session-meta {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-sm);
    }

    .meta-item {
      justify-content: space-between;
    }
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .error-container,
    .page-header {
      border-width: 2px;
    }

    .error-action {
      border-width: 2px;
    }

    .status-badge {
      border: 2px solid currentColor;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .error-action,
    .loading-spinner {
      animation: none;
      transition: none;
    }

    .error-action:hover {
      transform: none;
    }

    .status-badge.live .status-dot {
      animation: none;
    }

    .loading-spinner {
      border-top-color: var(--color-border);
    }
  }

  /* Dark mode support */
  @media (prefers-color-scheme: dark) {
    .error-container {
      background-color: #450a0a;
      border-color: #7f1d1d;
    }

    .error-title,
    .error-message {
      color: #fca5a5;
    }

    .error-action.primary {
      background-color: #ef4444;
    }

    .error-action.primary:hover {
      background-color: #dc2626;
    }

    .error-action.secondary {
      color: #fca5a5;
      border-color: #ef4444;
    }

    .error-action.secondary:hover {
      background-color: #ef4444;
      color: white;
    }

    .status-badge.live {
      background-color: #064e3b;
      color: #a7f3d0;
    }
  }

  /* Print styles */
  @media print {
    .presenter-control-page {
      background: white;
    }

    .error-actions,
    .loading-spinner,
    .status-dot {
      display: none;
    }

    .page-title {
      color: black;
    }
  }
</style>