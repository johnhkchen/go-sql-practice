---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { API_BASE, FETCH_TIMEOUT, apiFetch, ApiError } from '../../lib/api';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

let session = null;
let error = null;

try {
  session = await apiFetch(`${API_BASE}/api/collections/sync_sessions/records/${id}`, {
    headers: {
      'Accept': 'application/json'
    },
    timeout: FETCH_TIMEOUT
  });
} catch (err) {
  if (err instanceof ApiError) {
    if (err.code === 'timeout') {
      error = 'timeout';
    } else if (err.code === 'notfound' || err.status === 404) {
      error = 'session_not_found';
    } else {
      error = 'server_error';
    }
  } else {
    error = 'network_error';
  }
}

const errorMessages = {
  session_not_found: {
    title: 'Session Not Found',
    message: 'This sync session does not exist or has been removed.'
  },
  network_error: {
    title: 'Connection Error',
    message: 'Unable to connect to the server. Please check your connection and try again.'
  },
  server_error: {
    title: 'Server Error',
    message: 'Something went wrong on our end. Please try again later.'
  },
  timeout: {
    title: 'Request Timeout',
    message: 'The request took too long. Please try again.'
  }
};

const pageTitle = session ? `Sync Viewer - Session ${id}` : (error ? 'Error' : 'Loading...');
---

<BaseLayout title={pageTitle}>
  <div class="sync-viewer-container">
    <h1>Sync Viewer</h1>

    {error && (
      <div class="error-container">
        <h2 class="error-title">{errorMessages[error].title}</h2>
        <p class="error-message">{errorMessages[error].message}</p>
        <a href="/" class="back-link">← Back to Home</a>
      </div>
    )}

    {session && (
      <div class="session-container">
        <div class="connection-status">
          <span class="status-indicator" id="status-indicator"></span>
          <span class="status-text" id="status-text">Connecting...</span>
          <span class="last-update" id="last-update"></span>
        </div>

        <div class="progress-section">
          <h2 id="progress-heading">Session Progress</h2>
          <div class="progress-container">
            <progress
              class="progress-bar"
              id="progress-bar"
              value={session.progress}
              max="1"
              aria-labelledby="progress-heading"
              aria-describedby="progress-description">
            </progress>
            <div class="progress-label" id="progress-label">
              {Math.round(session.progress * 100).toFixed(1)}%
            </div>
          </div>
          <div id="progress-description" class="progress-help">
            This progress bar updates automatically as the session advances
          </div>
        </div>

        <div class="session-info">
          <h2>Session Information</h2>
          <div class="info-grid">
            <div class="info-item">
              <label>Session ID:</label>
              <code>{session.id}</code>
            </div>
            <div class="info-item">
              <label>Current Progress:</label>
              <code>{session.progress.toFixed(3)}</code>
            </div>
            <div class="info-item">
              <label>Created:</label>
              <span>{new Date(session.created).toLocaleString()}</span>
            </div>
            <div class="info-item">
              <label>Last Updated:</label>
              <span>{new Date(session.updated).toLocaleString()}</span>
            </div>
          </div>
        </div>
      </div>
    )}
  </div>
</BaseLayout>

{session && (
  <script define:vars={{ sessionId: id, initialProgress: session.progress }}>
    import { SyncViewer } from '../../lib/syncViewer';

    const apiBase = import.meta.env.PUBLIC_API_URL || '';
    const syncViewer = new SyncViewer(sessionId, initialProgress, apiBase);
  </script>
)}

<style>
  .sync-viewer-container {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-lg);
  }

  .sync-viewer-container h1 {
    margin-bottom: var(--space-lg);
  }

  /* Error States */
  .error-container {
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    padding: var(--space-lg);
    text-align: center;
  }

  .error-title {
    color: #dc2626;
    margin-bottom: var(--space-md);
    font-size: 1.5rem;
  }

  .error-message {
    color: #dc2626;
    margin-bottom: var(--space-lg);
  }

  .back-link {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    transition: background-color 0.2s ease;
    display: inline-block;
  }

  .back-link:hover {
    background-color: var(--color-footer);
    text-decoration: none;
  }

  /* Connection Status */
  .connection-status {
    background-color: var(--color-footer);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-md) var(--space-lg);
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .status-indicator {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .status-indicator.connected {
    background-color: #10b981;
    box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2);
  }

  .status-indicator.connecting {
    background-color: #f59e0b;
    box-shadow: 0 0 0 2px rgba(245, 158, 11, 0.2);
    animation: pulse 2s infinite;
  }

  .status-indicator.disconnected {
    background-color: #ef4444;
    box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.2);
  }

  .status-text {
    font-weight: 500;
    font-size: 0.875rem;
  }

  .last-update {
    margin-left: auto;
    font-size: 0.75rem;
    color: var(--color-text);
    opacity: 0.7;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  /* Session Content */
  .session-container {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .progress-section,
  .session-info {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-lg);
  }

  .progress-section h2,
  .session-info h2 {
    color: var(--color-primary);
    margin-bottom: var(--space-md);
    font-size: 1.25rem;
  }

  /* Progress Display */
  .progress-container {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .progress-bar {
    flex: 1;
    height: 24px;
    border-radius: 12px;
    border: none;
    background-color: var(--color-border);
    transition: all 0.3s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  .progress-bar::-webkit-progress-bar {
    background-color: var(--color-border);
    border-radius: 12px;
  }

  .progress-bar::-webkit-progress-value {
    background-color: var(--color-primary);
    border-radius: 12px;
    transition: width 0.3s ease;
  }

  .progress-bar::-moz-progress-bar {
    background-color: var(--color-primary);
    border-radius: 12px;
  }

  .progress-label {
    min-width: 60px;
    text-align: center;
    font-family: monospace;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .progress-help {
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.7;
    font-style: italic;
  }

  /* Session Info Grid */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-md);
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .info-item label {
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.8;
  }

  .info-item code {
    background-color: var(--color-footer);
    padding: var(--space-xs) var(--space-sm);
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.875rem;
    word-break: break-all;
  }

  /* Dark mode support */
  @media (prefers-color-scheme: dark) {
    .error-container {
      background-color: #450a0a;
      border-color: #7f1d1d;
    }

    .error-title,
    .error-message {
      color: #fca5a5;
    }
  }

  /* Responsive Design */
  @media (max-width: 767px) {
    .sync-viewer-container {
      padding: var(--space-md);
    }

    .info-grid {
      grid-template-columns: 1fr;
    }

    .progress-container {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-md);
    }

    .progress-label {
      text-align: center;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .progress-bar,
    .progress-bar::-webkit-progress-value {
      transition: none;
    }

    .status-indicator.connecting {
      animation: none;
    }

    .status-indicator {
      transition: none;
    }
  }
</style>