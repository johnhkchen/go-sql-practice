---
// Disable prerendering for SSR
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { API_BASE, FETCH_TIMEOUT, apiFetch, ApiError } from '../../../lib/api';

// Get session ID from URL parameters
const { id } = Astro.params;

// Get admin token from query string
const token = Astro.url.searchParams.get('token');

// Basic validation
if (!id) {
  return Astro.redirect('/404');
}

// Session data and error state
let session = null;
let error = null;

if (!token) {
  error = 'missing_token';
}

try {
  // Fetch session data with timeout
  const sessionData = await apiFetch(`${API_BASE}/api/collections/sync_sessions/records/${id}`, {
    headers: {
      'Accept': 'application/json'
    },
    timeout: FETCH_TIMEOUT
  });

    // Validate admin token (constant-time comparison would be ideal, but this is frontend)
    if (sessionData.admin_token === token) {
      session = sessionData;
    } else {
      error = 'invalid_token';
    }
} catch (err) {
  if (err instanceof ApiError) {
    if (err.code === 'timeout') {
      error = 'timeout';
    } else if (err.code === 'notfound' || err.status === 404) {
      error = 'session_not_found';
    } else {
      error = 'server_error';
    }
  } else {
    error = 'network_error';
  }
}

// Error messages
const errorMessages = {
  missing_token: {
    title: 'Missing Admin Token',
    message: 'Admin token is required. Please check your URL and try again.'
  },
  invalid_token: {
    title: 'Access Denied',
    message: 'Invalid admin token. Please check your URL and try again.'
  },
  session_not_found: {
    title: 'Session Not Found',
    message: 'This sync session does not exist or has been removed.'
  },
  network_error: {
    title: 'Connection Error',
    message: 'Unable to connect to the server. Please check your connection and try again.'
  },
  server_error: {
    title: 'Server Error',
    message: 'Something went wrong on our end. Please try again later.'
  },
  timeout: {
    title: 'Request Timeout',
    message: 'The request took too long. Please try again.'
  }
};

const pageTitle = session ? `Sync Control - Session ${id}` : (error ? 'Error' : 'Loading...');
const viewerUrl = `/sync/${id}`;
---

<BaseLayout title={pageTitle}>
  <div class="sync-control-container">
    <h1>Sync Control</h1>

    {error && (
      <div class="error-container">
        <h2 class="error-title">{errorMessages[error].title}</h2>
        <p class="error-message">{errorMessages[error].message}</p>
        <a href="/" class="back-link">← Back to Home</a>
      </div>
    )}

    {session && (
      <div class="session-container">
        <div class="session-info">
          <h2>Session Information</h2>
          <div class="info-grid">
            <div class="info-item">
              <label>Session ID:</label>
              <code>{session.id}</code>
            </div>
            <div class="info-item">
              <label>Current Progress:</label>
              <code>{session.progress}</code>
            </div>
            <div class="info-item">
              <label>Created:</label>
              <span>{new Date(session.created).toLocaleString()}</span>
            </div>
            <div class="info-item">
              <label>Last Updated:</label>
              <span>{new Date(session.updated).toLocaleString()}</span>
            </div>
          </div>
        </div>

        <div class="progress-section">
          <h2 id="progress-control-heading">Progress Control</h2>
          <p>Use the slider to control the sync progress (0 to 1):</p>

          <div class="progress-controls" role="group" aria-labelledby="progress-control-heading">
            <label for="progress-slider" class="visually-hidden">
              Sync progress from 0 to 1
            </label>
            <input
              type="range"
              id="progress-slider"
              min="0"
              max="1"
              step="0.001"
              value={session.progress}
              class="progress-slider"
              aria-describedby="progress-value progress-help"
              aria-valuemin="0"
              aria-valuemax="1"
              aria-valuenow={session.progress}
              aria-valuetext={`${session.progress} out of 1`}
            />
            <div class="progress-display" id="progress-value" aria-live="polite" aria-atomic="true">
              <span>{session.progress}</span>
            </div>
          </div>
          <div id="progress-help" class="help-text">
            Changes are automatically saved. Use arrow keys for precise adjustments.
          </div>
        </div>

        <div class="viewer-section">
          <h2 id="viewer-url-heading">Viewer URL</h2>
          <p>Share this URL with viewers:</p>

          <div class="url-container" role="group" aria-labelledby="viewer-url-heading">
            <label for="viewer-url" class="visually-hidden">
              Viewer URL for sharing with others
            </label>
            <input
              type="text"
              id="viewer-url"
              value={`${Astro.url.origin}${viewerUrl}`}
              readonly
              class="viewer-url-input"
              aria-describedby="copy-help"
              aria-label="Viewer URL for sharing with others"
            />
            <button
              type="button"
              id="copy-button"
              class="copy-button"
              aria-describedby="copy-help"
              title="Copy viewer URL to clipboard"
            >
              Copy
            </button>
          </div>
          <div id="copy-help" class="help-text">
            Click the Copy button or select the URL text to copy.
          </div>
        </div>

      </div>
    )}
  </div>
</BaseLayout>

{session && (
  <script client:load type="module" define:vars={{ sessionId: id, adminToken: token, initialProgress: session.progress, apiBase: API_BASE }}>
    // Import and use SyncController from extracted module
    import { SyncController } from '../../../lib/syncController.js';
      constructor(sessionId, adminToken, initialProgress, apiBase) {
        this.sessionId = sessionId;
        this.adminToken = adminToken;
        this.currentProgress = initialProgress;
        this.apiBase = apiBase;

        // DOM elements
        this.progressSlider = null;
        this.progressValue = null;
        this.copyButton = null;
        this.viewerUrlInput = null;

        // State management
        this.isUpdating = false;
        this.throttleTimeout = null;

        // Initialize
        this.init();
      }

      init() {
        // Wait for DOM to be ready
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', () => this.setupDOM());
        } else {
          this.setupDOM();
        }
      }

      setupDOM() {
        // Select DOM elements
        this.progressSlider = document.getElementById('progress-slider');
        this.progressValue = document.getElementById('progress-value');
        this.copyButton = document.getElementById('copy-button');
        this.viewerUrlInput = document.getElementById('viewer-url');

        // Validate DOM elements exist
        if (!this.progressSlider || !this.progressValue || !this.copyButton || !this.viewerUrlInput) {
          console.warn('SyncController: Some DOM elements not found. Page may not be fully loaded.');
          return;
        }

        // Set up event listeners
        this.setupEventListeners();

      }

      setupEventListeners() {
        // Progress slider event listener
        this.progressSlider.addEventListener('input', (e) => {
          this.updateProgress(parseFloat(e.target.value));
        });

        // Enhanced keyboard support for slider
        this.progressSlider.addEventListener('keydown', (e) => {
          this.handleSliderKeyboard(e);
        });

        // Copy button event listener
        this.copyButton.addEventListener('click', () => {
          this.copyToClipboard();
        });

        // Enhanced keyboard support for copy button
        this.copyButton.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            this.copyToClipboard();
          }
        });

        // URL input selection on focus for easy copying
        this.viewerUrlInput.addEventListener('focus', () => {
          this.viewerUrlInput.select();
        });

      }

      handleSliderKeyboard(e) {
        let increment = 0;

        switch (e.key) {
          case 'ArrowRight':
          case 'ArrowUp':
            increment = e.shiftKey ? 0.01 : e.ctrlKey ? 0.1 : 0.001;
            break;
          case 'ArrowLeft':
          case 'ArrowDown':
            increment = e.shiftKey ? -0.01 : e.ctrlKey ? -0.1 : -0.001;
            break;
          case 'Home':
            e.preventDefault();
            this.updateProgress(0);
            return;
          case 'End':
            e.preventDefault();
            this.updateProgress(1);
            return;
          case 'PageUp':
            increment = 0.1;
            break;
          case 'PageDown':
            increment = -0.1;
            break;
          default:
            return; // Let default behavior handle other keys
        }

        if (increment !== 0) {
          e.preventDefault();
          const newValue = parseFloat(this.progressSlider.value) + increment;
          this.progressSlider.value = Math.max(0, Math.min(1, newValue));
          this.updateProgress(parseFloat(this.progressSlider.value));
        }
      }

      updateProgress(value) {
        // Validate progress value (0-1 range)
        const validatedValue = this.validateProgress(value);

        // Update local state
        this.currentProgress = validatedValue;

        // Update UI display immediately for responsiveness
        this.updateProgressDisplay(validatedValue);

        // Throttle API updates to prevent flooding (max 30 updates/sec = ~33ms)
        this.throttledUpdate(validatedValue);
      }

      updateProgressDisplay(value) {
        // Update the numeric display
        this.progressValue.querySelector('span').textContent = value.toFixed(3);

        // Update ARIA attributes for accessibility
        this.progressSlider.setAttribute('aria-valuenow', value);
        this.progressSlider.setAttribute('aria-valuetext', `${value.toFixed(3)} out of 1`);

        // Add visual feedback during update
        this.progressValue.style.color = 'var(--color-primary)';
        this.progressValue.style.fontWeight = '700';

        // Reset styling after brief delay
        setTimeout(() => {
          this.progressValue.style.color = '';
          this.progressValue.style.fontWeight = '';
        }, 150);

        // Announce significant changes to screen readers
        if (Math.abs(value - this.lastAnnouncedValue) >= 0.1 || !this.lastAnnouncedValue) {
          this.announceProgressChange(value);
          this.lastAnnouncedValue = value;
        }
      }

      announceProgressChange(value) {
        // Create screen reader announcement for significant progress changes
        const announcement = document.createElement('div');
        announcement.setAttribute('aria-live', 'polite');
        announcement.setAttribute('aria-atomic', 'true');
        announcement.className = 'sr-only';

        const percentage = Math.round(value * 100);
        announcement.textContent = `Progress updated to ${percentage}%`;

        document.body.appendChild(announcement);

        // Remove announcement after screen readers have processed it
        setTimeout(() => {
          if (document.body.contains(announcement)) {
            document.body.removeChild(announcement);
          }
        }, 1000);
      }

      validateProgress(value) {
        // Ensure value is a number and within valid range
        if (typeof value !== 'number' || isNaN(value)) {
          return this.currentProgress; // Return previous valid value
        }

        // Clamp to valid range (0-1)
        return Math.max(0, Math.min(1, value));
      }

      throttledUpdate(value) {
        // Clear any existing timeout
        if (this.throttleTimeout) {
          clearTimeout(this.throttleTimeout);
        }

        // Set new timeout for API update (33ms = ~30 updates/sec max)
        this.throttleTimeout = setTimeout(() => {
          this.sendProgressUpdate(value);
        }, 33);
      }

      async sendProgressUpdate(value) {
        // Prevent concurrent updates
        if (this.isUpdating) {
          return;
        }

        this.isUpdating = true;

        try {
          // Add visual feedback for API call
          this.addUpdateFeedback('updating');

          const response = await fetch(`${this.apiBase}/api/sync/${this.sessionId}/progress`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({
              progress: value,
              token: this.adminToken
            })
          });

          if (response.ok) {
            const result = await response.json();
            this.addUpdateFeedback('success');

            // Update local state with server response if provided
            if (result.progress !== undefined) {
              this.currentProgress = result.progress;
              this.updateProgressDisplay(result.progress);
            }
          } else {
            // Handle different error responses
            let errorMessage = 'Failed to update progress';

            if (response.status === 403) {
              errorMessage = 'Invalid admin token';
              this.handleError('invalid_token');
            } else if (response.status === 404) {
              errorMessage = 'Session not found';
              this.handleError('session_not_found');
            } else if (response.status === 400) {
              const errorData = await response.json().catch(() => ({}));
              errorMessage = errorData.message || 'Invalid request';
              this.handleError('validation_error', errorMessage);
            } else {
              errorMessage = `Server error (${response.status})`;
              this.handleError('server_error');
            }

            console.error('API Error:', errorMessage);
            this.addUpdateFeedback('error', errorMessage);
          }
        } catch (error) {
          console.error('Network error:', error);

          let errorMessage = 'Network error';
          if (error.name === 'TypeError' && error.message.includes('fetch')) {
            errorMessage = 'Unable to connect to server';
          }

          this.handleError('network_error', errorMessage);
          this.addUpdateFeedback('error', errorMessage);
        } finally {
          this.isUpdating = false;
        }
      }

      addUpdateFeedback(type, message = '') {
        // Remove any existing feedback
        this.removeUpdateFeedback();

        const feedbackElement = document.createElement('div');
        feedbackElement.className = `update-feedback update-feedback-${type}`;
        feedbackElement.id = 'update-feedback';

        let content = '';
        switch (type) {
          case 'updating':
            content = '<span>Updating...</span>';
            break;
          case 'success':
            content = '<span>✓ Updated</span>';
            break;
          case 'error':
            content = `<span>⚠ ${message || 'Update failed'}</span>`;
            break;
        }

        feedbackElement.innerHTML = content;

        // Insert feedback near progress display
        const progressControls = document.querySelector('.progress-controls');
        if (progressControls) {
          progressControls.appendChild(feedbackElement);
        }

        // Auto-remove success/error feedback after delay
        if (type === 'success' || type === 'error') {
          setTimeout(() => {
            this.removeUpdateFeedback();
          }, type === 'success' ? 2000 : 5000);
        }
      }

      removeUpdateFeedback() {
        const existing = document.getElementById('update-feedback');
        if (existing) {
          existing.remove();
        }
      }

      async copyToClipboard() {
        const viewerUrl = this.viewerUrlInput.value;

        try {
          // Modern Clipboard API (preferred)
          if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText(viewerUrl);
            this.showCopyFeedback('success');
            this.announceCopySuccess();
          } else {
            // Fallback to legacy method
            this.copyWithLegacyMethod(viewerUrl);
          }
        } catch (error) {
          console.error('Copy failed:', error);

          // Try fallback method if modern API fails
          try {
            this.copyWithLegacyMethod(viewerUrl);
          } catch (fallbackError) {
            console.error('Fallback copy also failed:', fallbackError);
            this.showCopyFeedback('error', 'Copy failed. Please copy the URL manually.');
          }
        }
      }

      copyWithLegacyMethod(text) {
        // Create a temporary textarea
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        textarea.style.left = '-9999px';
        textarea.setAttribute('aria-hidden', 'true');

        document.body.appendChild(textarea);

        try {
          // Select and copy
          textarea.select();
          textarea.setSelectionRange(0, 99999); // For mobile devices

          const successful = document.execCommand('copy');

          if (successful) {
            this.showCopyFeedback('success');
            this.announceCopySuccess();
          } else {
            throw new Error('execCommand copy failed');
          }
        } finally {
          document.body.removeChild(textarea);
        }
      }

      showCopyFeedback(type, message = '') {
        // Remove any existing feedback
        const existing = document.querySelector('.copy-feedback');
        if (existing) {
          existing.remove();
        }

        const originalText = this.copyButton.textContent;

        if (type === 'success') {
          this.copyButton.textContent = '✓ Copied!';
          this.copyButton.classList.add('copy-success');

          // Reset after delay
          setTimeout(() => {
            this.copyButton.textContent = originalText;
            this.copyButton.classList.remove('copy-success');
          }, 2000);

        } else if (type === 'error') {
          this.copyButton.textContent = '⚠ Error';
          this.copyButton.classList.add('copy-error');

          // Show error message in tooltip-like element
          const feedbackElement = document.createElement('div');
          feedbackElement.className = 'copy-feedback copy-feedback-error';
          feedbackElement.textContent = message || 'Copy failed';

          const urlContainer = document.querySelector('.url-container');
          if (urlContainer) {
            urlContainer.appendChild(feedbackElement);

            // Remove error feedback after delay
            setTimeout(() => {
              feedbackElement.remove();
            }, 5000);
          }

          // Reset button after delay
          setTimeout(() => {
            this.copyButton.textContent = originalText;
            this.copyButton.classList.remove('copy-error');
          }, 3000);
        }
      }

      announceCopySuccess() {
        // Create screen reader announcement
        const announcement = document.createElement('div');
        announcement.setAttribute('aria-live', 'polite');
        announcement.setAttribute('aria-atomic', 'true');
        announcement.style.position = 'absolute';
        announcement.style.left = '-10000px';
        announcement.style.width = '1px';
        announcement.style.height = '1px';
        announcement.style.overflow = 'hidden';

        announcement.textContent = 'Viewer URL copied to clipboard';

        document.body.appendChild(announcement);

        // Remove announcement element after screen readers have processed it
        setTimeout(() => {
          document.body.removeChild(announcement);
        }, 1000);
      }

      handleError(errorType, message = '') {
        console.error('SyncController error:', errorType, message);

        switch (errorType) {
          case 'invalid_token':
            this.showErrorRecovery('invalid_token', 'Invalid admin token. Please check your URL and refresh the page.');
            break;

          case 'session_not_found':
            this.showErrorRecovery('session_not_found', 'Session not found. It may have been deleted.');
            break;

          case 'network_error':
            this.showNetworkError();
            break;

          case 'server_error':
            this.showErrorRecovery('server_error', 'Server error. Please try again later.');
            break;

          case 'validation_error':
            this.showErrorRecovery('validation_error', message || 'Invalid request.');
            break;

          default:
            this.showErrorRecovery('unknown_error', message || 'An unexpected error occurred.');
        }
      }

      showErrorRecovery(errorType, message) {
        // Create error dialog
        const errorDialog = this.createErrorDialog(errorType, message);
        document.body.appendChild(errorDialog);

        // Focus the dialog for accessibility
        const firstButton = errorDialog.querySelector('button');
        if (firstButton) {
          firstButton.focus();
        }
      }

      showNetworkError() {
        // Network errors get special treatment with retry functionality
        const errorDialog = this.createNetworkErrorDialog();
        document.body.appendChild(errorDialog);

        const retryButton = errorDialog.querySelector('.retry-button');
        if (retryButton) {
          retryButton.focus();
        }
      }

      createErrorDialog(errorType, message) {
        const dialog = document.createElement('div');
        dialog.className = 'error-dialog-overlay';
        dialog.setAttribute('role', 'dialog');
        dialog.setAttribute('aria-modal', 'true');
        dialog.setAttribute('aria-labelledby', 'error-title');

        dialog.innerHTML = `
          <div class="error-dialog">
            <div class="error-dialog-header">
              <h3 id="error-title">⚠ Error</h3>
            </div>
            <div class="error-dialog-body">
              <p>${message}</p>
            </div>
            <div class="error-dialog-actions">
              <button type="button" class="error-dialog-button primary" onclick="location.reload()">
                Reload Page
              </button>
              <button type="button" class="error-dialog-button secondary" onclick="this.closest('.error-dialog-overlay').remove()">
                Dismiss
              </button>
            </div>
          </div>
        `;

        // Close on escape key
        dialog.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            dialog.remove();
          }
        });

        // Close on overlay click
        dialog.addEventListener('click', (e) => {
          if (e.target === dialog) {
            dialog.remove();
          }
        });

        return dialog;
      }

      createNetworkErrorDialog() {
        const dialog = document.createElement('div');
        dialog.className = 'error-dialog-overlay';
        dialog.setAttribute('role', 'dialog');
        dialog.setAttribute('aria-modal', 'true');
        dialog.setAttribute('aria-labelledby', 'error-title');

        dialog.innerHTML = `
          <div class="error-dialog">
            <div class="error-dialog-header">
              <h3 id="error-title">🌐 Connection Problem</h3>
            </div>
            <div class="error-dialog-body">
              <p>Unable to connect to the server. Please check your connection and try again.</p>
              <div class="connection-status" id="connection-status">
                <span class="status-indicator offline"></span>
                <span class="status-text">Offline</span>
              </div>
            </div>
            <div class="error-dialog-actions">
              <button type="button" class="error-dialog-button primary retry-button" onclick="this.retryConnection(this)">
                Retry Connection
              </button>
              <button type="button" class="error-dialog-button secondary" onclick="this.closest('.error-dialog-overlay').remove()">
                Continue Offline
              </button>
            </div>
          </div>
        `;

        // Add retry functionality
        const retryButton = dialog.querySelector('.retry-button');
        retryButton.addEventListener('click', () => {
          this.testConnection(dialog);
        });

        // Monitor online/offline status
        this.setupConnectionMonitoring(dialog);

        return dialog;
      }

      async testConnection(dialog) {
        const statusIndicator = dialog.querySelector('.status-indicator');
        const statusText = dialog.querySelector('.status-text');
        const retryButton = dialog.querySelector('.retry-button');

        // Update UI to show testing
        statusIndicator.className = 'status-indicator testing';
        statusText.textContent = 'Testing...';
        retryButton.disabled = true;

        try {
          // Test connection with a simple API call
          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 5000);

          const response = await fetch(`${this.apiBase}/api/health`, {
            method: 'GET',
            signal: controller.signal
          });

          clearTimeout(timeoutId);

          if (response.ok) {
            // Connection successful
            statusIndicator.className = 'status-indicator online';
            statusText.textContent = 'Connected';
            retryButton.textContent = 'Close';
            retryButton.disabled = false;

            // Close dialog after brief delay
            setTimeout(() => {
              dialog.remove();
            }, 1000);
          } else {
            throw new Error('Server responded with error');
          }
        } catch (error) {
          // Connection still failing
          statusIndicator.className = 'status-indicator offline';
          statusText.textContent = 'Still offline';
          retryButton.disabled = false;
        }
      }

      setupConnectionMonitoring(dialog) {
        const statusIndicator = dialog.querySelector('.status-indicator');
        const statusText = dialog.querySelector('.status-text');

        // Update status based on navigator.onLine
        const updateStatus = () => {
          if (navigator.onLine) {
            statusIndicator.className = 'status-indicator online';
            statusText.textContent = 'Back online';
          } else {
            statusIndicator.className = 'status-indicator offline';
            statusText.textContent = 'Offline';
          }
        };

        // Listen for online/offline events
        window.addEventListener('online', updateStatus);
        window.addEventListener('offline', updateStatus);

        // Clean up event listeners when dialog is removed
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            mutation.removedNodes.forEach((node) => {
              if (node === dialog) {
                window.removeEventListener('online', updateStatus);
                window.removeEventListener('offline', updateStatus);
                observer.disconnect();
              }
            });
          });
        });

        observer.observe(document.body, { childList: true });

        // Initial status update
        updateStatus();
      }

      // Graceful degradation check
      checkJavaScriptSupport() {
        // This method exists to provide a hook for checking if JS is working
        // If it's not called, we know JavaScript is disabled
        document.documentElement.classList.add('js-enabled');
      }
    }

    // Initialize controller when script loads
    const syncController = new SyncController(sessionId, adminToken, initialProgress, apiBase);

    // Mark that JavaScript is enabled for graceful degradation
    syncController.checkJavaScriptSupport();
  </script>
)}

<style>
  .sync-control-container {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-lg);
  }

  .sync-control-container h1 {
    margin-bottom: var(--space-lg);
  }

  /* Error States */
  .error-container {
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    padding: var(--space-lg);
    text-align: center;
  }

  .error-title {
    color: #dc2626;
    margin-bottom: var(--space-md);
    font-size: 1.5rem;
  }

  .error-message {
