---
// Disable prerendering for SSR
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';

// Get session ID from URL parameters
const { id } = Astro.params;

// Get admin token from query string
const token = Astro.url.searchParams.get('token');

// Basic validation
if (!id) {
  return Astro.redirect('/404');
}

if (!token) {
  error = 'missing_token';
}

// API configuration
const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:8090';
const FETCH_TIMEOUT = 5000;

// Session data and error state
let session = null;
let error = null;

try {
  // Fetch session data with timeout
  const controller = new AbortController();
  const timeoutId = setTimeout(() => controller.abort(), FETCH_TIMEOUT);

  const response = await fetch(`${API_BASE}/api/collections/sync_sessions/records/${id}`, {
    signal: controller.signal,
    headers: {
      'Accept': 'application/json'
    }
  });

  clearTimeout(timeoutId);

  if (response.ok) {
    const sessionData = await response.json();

    // Validate admin token (constant-time comparison would be ideal, but this is frontend)
    if (sessionData.admin_token === token) {
      session = sessionData;
    } else {
      error = 'invalid_token';
    }
  } else if (response.status === 404) {
    error = 'session_not_found';
  } else {
    error = 'server_error';
  }
} catch (err) {
  if (err.name === 'AbortError') {
    error = 'timeout';
  } else {
    error = 'network_error';
  }
}

// Error messages
const errorMessages = {
  missing_token: {
    title: 'Missing Admin Token',
    message: 'Admin token is required. Please check your URL and try again.'
  },
  invalid_token: {
    title: 'Access Denied',
    message: 'Invalid admin token. Please check your URL and try again.'
  },
  session_not_found: {
    title: 'Session Not Found',
    message: 'This sync session does not exist or has been removed.'
  },
  network_error: {
    title: 'Connection Error',
    message: 'Unable to connect to the server. Please check your connection and try again.'
  },
  server_error: {
    title: 'Server Error',
    message: 'Something went wrong on our end. Please try again later.'
  },
  timeout: {
    title: 'Request Timeout',
    message: 'The request took too long. Please try again.'
  }
};

const pageTitle = session ? `Sync Control - Session ${id}` : (error ? 'Error' : 'Loading...');
const viewerUrl = `/sync/${id}`;
---

<BaseLayout title={pageTitle}>
  <div class="sync-control-container">
    <h1>Sync Control</h1>

    {error && (
      <div class="error-container">
        <h2 class="error-title">{errorMessages[error].title}</h2>
        <p class="error-message">{errorMessages[error].message}</p>
        <a href="/" class="back-link">← Back to Home</a>
      </div>
    )}

    {session && (
      <div class="session-container">
        <div class="session-info">
          <h2>Session Information</h2>
          <div class="info-grid">
            <div class="info-item">
              <label>Session ID:</label>
              <code>{session.id}</code>
            </div>
            <div class="info-item">
              <label>Current Progress:</label>
              <code>{session.progress}</code>
            </div>
            <div class="info-item">
              <label>Created:</label>
              <span>{new Date(session.created).toLocaleString()}</span>
            </div>
            <div class="info-item">
              <label>Last Updated:</label>
              <span>{new Date(session.updated).toLocaleString()}</span>
            </div>
          </div>
        </div>

        <div class="progress-section">
          <h2>Progress Control</h2>
          <p>Use the slider to control the sync progress (0 to 1):</p>

          <div class="progress-controls">
            <input
              type="range"
              id="progress-slider"
              min="0"
              max="1"
              step="0.001"
              value={session.progress}
              class="progress-slider"
            />
            <div class="progress-display">
              <span id="progress-value">{session.progress}</span>
            </div>
          </div>
        </div>

        <div class="viewer-section">
          <h2>Viewer URL</h2>
          <p>Share this URL with viewers:</p>

          <div class="url-container">
            <input
              type="text"
              id="viewer-url"
              value={`${Astro.url.origin}${viewerUrl}`}
              readonly
              class="viewer-url-input"
            />
            <button
              type="button"
              id="copy-button"
              class="copy-button"
            >
              Copy
            </button>
          </div>
        </div>

        <div class="temp-debug">
          <h3>Debug Info (will be removed)</h3>
          <p>Server-side data fetching working!</p>
          <p>Next: Add client-side interactivity</p>
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .sync-control-container {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-lg);
  }

  .sync-control-container h1 {
    margin-bottom: var(--space-lg);
  }

  /* Error States */
  .error-container {
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    padding: var(--space-lg);
    text-align: center;
  }

  .error-title {
    color: #dc2626;
    margin-bottom: var(--space-md);
    font-size: 1.5rem;
  }

  .error-message {
    color: #dc2626;
    margin-bottom: var(--space-lg);
  }

  .back-link {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    transition: background-color 0.2s ease;
    display: inline-block;
  }

  .back-link:hover {
    background-color: var(--color-footer);
    text-decoration: none;
  }

  /* Session Content */
  .session-container {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .session-info,
  .progress-section,
  .viewer-section {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-lg);
  }

  .session-info h2,
  .progress-section h2,
  .viewer-section h2 {
    color: var(--color-primary);
    margin-bottom: var(--space-md);
    font-size: 1.25rem;
  }

  /* Session Info Grid */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-md);
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .info-item label {
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.8;
  }

  .info-item code {
    background-color: var(--color-footer);
    padding: var(--space-xs) var(--space-sm);
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.875rem;
    word-break: break-all;
  }

  /* Progress Controls */
  .progress-section p {
    margin-bottom: var(--space-lg);
    opacity: 0.8;
  }

  .progress-controls {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .progress-slider {
    flex: 1;
    height: 8px;
    background: var(--color-border);
    border-radius: 4px;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
  }

  .progress-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 24px;
    height: 24px;
    background: var(--color-primary);
    border-radius: 50%;
    cursor: pointer;
  }

  .progress-slider::-moz-range-thumb {
    width: 24px;
    height: 24px;
    background: var(--color-primary);
    border-radius: 50%;
    cursor: pointer;
    border: none;
  }

  .progress-display {
    min-width: 80px;
    text-align: center;
  }

  #progress-value {
    font-family: monospace;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  /* Viewer URL Section */
  .viewer-section p {
    margin-bottom: var(--space-lg);
    opacity: 0.8;
  }

  .url-container {
    display: flex;
    gap: var(--space-md);
  }

  .viewer-url-input {
    flex: 1;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background-color: var(--color-footer);
    font-family: monospace;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .viewer-url-input:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .copy-button {
    padding: var(--space-sm) var(--space-lg);
    background-color: var(--color-primary);
    color: var(--color-bg);
    border: none;
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.1s ease;
    white-space: nowrap;
  }

  .copy-button:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .copy-button:active {
    transform: translateY(0);
  }

  .copy-button:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Debug section (temporary) */
  .temp-debug {
    background-color: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 8px;
    padding: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .temp-debug h3 {
    color: #059669;
    margin-bottom: var(--space-md);
    font-size: 1rem;
  }

  .temp-debug p {
    color: #059669;
    margin-bottom: var(--space-sm);
    font-style: italic;
  }

  .temp-debug p:last-child {
    margin-bottom: 0;
  }

  /* Responsive Design */
  @media (max-width: 767px) {
    .sync-control-container {
      padding: var(--space-md);
    }

    .info-grid {
      grid-template-columns: 1fr;
    }

    .progress-controls {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-md);
    }

    .progress-display {
      text-align: center;
    }

    .url-container {
      flex-direction: column;
    }

    .copy-button {
      align-self: center;
      min-width: 120px;
    }
  }
</style>