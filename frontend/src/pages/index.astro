---
// Disable prerendering for SSR
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import SearchInterface from '../components/SearchInterface.astro';
import LinksList from '../components/LinksList.astro';
import ErrorState from '../components/ErrorState.astro';
import { API_BASE, FETCH_TIMEOUT, apiFetch, ApiError } from '../lib/api';
import type { LinkItem, SearchResponse, PocketBaseResponse } from '../types/api';

// URL parameter processing
const searchQuery = Astro.url.searchParams.get('q') || '';
const isSearchRequest = !!searchQuery;

// Data fetching with error handling
let links: LinkItem[] = [];
let totalCount = 0;
let error: string | null = null;

try {
  if (isSearchRequest) {
    // Use search API for queries
    const searchData = await apiFetch<SearchResponse>(
      `${API_BASE}/api/links/search?q=${encodeURIComponent(searchQuery)}`,
      { timeout: FETCH_TIMEOUT }
    );
    links = searchData.links || [];
    totalCount = searchData.total_count || 0;
  } else {
    // Use PocketBase collections API for initial load
    const pocketData = await apiFetch<PocketBaseResponse<LinkItem>>(
      `${API_BASE}/api/collections/links/records?page=1&perPage=50&sort=-created`,
      { timeout: FETCH_TIMEOUT }
    );
    links = pocketData.items || [];
    totalCount = pocketData.totalItems || 0;
  }
} catch (err) {
  if (err instanceof ApiError) {
    error = err.code;
  } else {
    error = 'network';
    console.error('Fetch error:', err);
  }
}

// Determine page title
const pageTitle = error
  ? 'Error - Link Bookmarks'
  : isSearchRequest
    ? `Search Results - Link Bookmarks`
    : 'Link Bookmarks';

// Error messages
const errorMessages = {
  notfound: {
    title: 'No Results Found',
    message: isSearchRequest
      ? `No links match your search for "${searchQuery}".`
      : 'No links are available at this time.'
  },
  network: {
    title: 'Connection Error',
    message: 'Unable to connect to the server. Please check your connection and try again.'
  },
  server: {
    title: 'Server Error',
    message: 'Something went wrong on our end. Please try again later.'
  },
  timeout: {
    title: 'Request Timeout',
    message: 'The request took too long. Please try again.'
  }
};
---

<BaseLayout title={pageTitle}>
  <div class="home-page-container">
    <!-- Search Interface -->
    <SearchInterface
      client:visible
      initialQuery={searchQuery}
      initialResults={isSearchRequest ? links : []}
      initialCount={totalCount}
      className="home-search-interface"
    />

    {/* Error State */}
    {error && (
      <ErrorState
        title={errorMessages[error].title}
        message={errorMessages[error].message}
        backLink="/"
        backLabel="← Home"
      />
    )}

    {/* Success State - Links List */}
    {!error && (
      <LinksList
        links={links}
        totalCount={totalCount}
        searchQuery={searchQuery}
        isSearchResult={isSearchRequest}
        className="home-links-list"
      />
    )}
  </div>
</BaseLayout>

<style>
  /* Main container */
  .home-page-container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-lg);
    min-height: 60vh;
  }

  /* Search interface specific styling */
  .home-search-interface {
    position: sticky;
    top: var(--space-md);
    z-index: 10;
    background-color: var(--color-bg);
    border-radius: 8px;
    padding: var(--space-lg);
    margin-bottom: var(--space-xl);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    border: 1px solid var(--color-border);
  }

  /* Links list specific styling */
  .home-links-list {
    margin-top: 0;
  }


  /* Responsive design */
  @media (max-width: 767px) {
    .home-page-container {
      padding: var(--space-md);
    }

    .home-search-interface {
      position: static;
      padding: var(--space-md);
      margin-bottom: var(--space-lg);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.1);
    }

    .error-title {
      font-size: 1.5rem;
    }

    .error-message {
      font-size: 1rem;
    }

    .error-actions {
      flex-direction: column;
      align-items: center;
    }

    .back-link,
    .retry-button {
      width: 200px;
      text-align: center;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .home-search-interface {
      padding: var(--space-md) var(--space-lg);
    }
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .home-search-interface {
      border-width: 2px;
    }

    .error-state {
      border: 2px solid var(--color-border);
      border-radius: 8px;
    }

    .back-link,
    .retry-button {
      border-width: 2px;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .home-search-interface {
      position: static;
    }

    .back-link,
    .retry-button {
      transition: none;
    }

    .retry-button:active {
      transform: none;
    }
  }

  /* Focus management */
  .home-search-interface:focus-within {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Loading state support (for future client-side enhancements) */
  .home-page-container[data-loading="true"] {
    opacity: 0.8;
  }

  .home-page-container[data-loading="true"] .home-search-interface {
    pointer-events: none;
  }
</style>

<script>
  // Progressive enhancement preparation

  // Track page view type for analytics (future enhancement)
  if (typeof window !== 'undefined') {
    const isSearch = new URLSearchParams(window.location.search).has('q');
  }
</script>