---
// Disable prerendering for SSR
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import LinkCard from '../../components/LinkCard.astro';
import ErrorState from '../../components/ErrorState.astro';
import { API_BASE, FETCH_TIMEOUT, apiFetch, ApiError } from '../../lib/api';
import type { LinkItem, SearchResponse } from '../../types/api';

// Get tag slug from URL
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

let searchResponse: SearchResponse | null = null;
let error: string | null = null;

try {
  searchResponse = await apiFetch<SearchResponse>(
    `${API_BASE}/api/links/search?tag=${encodeURIComponent(slug)}&page=1&per_page=50`,
    { timeout: FETCH_TIMEOUT }
  );
} catch (err) {
  if (err instanceof ApiError) {
    error = err.code;
  } else {
    error = 'network';
  }
}

// Determine view state
const hasLinks = searchResponse && searchResponse.links.length > 0;
const isEmpty = searchResponse && searchResponse.links.length === 0;

// Error messages
const errorMessages = {
  notfound: {
    title: 'Tag Not Found',
    message: 'This tag does not exist or has no associated links.'
  },
  network: {
    title: 'Connection Error',
    message: 'Unable to connect to the server. Please check your connection and try again.'
  },
  server: {
    title: 'Server Error',
    message: 'Something went wrong on our end. Please try again later.'
  },
  timeout: {
    title: 'Request Timeout',
    message: 'The request took too long. Please try again.'
  }
};

// Format tag name for display
const tagDisplayName = slug.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
const pageTitle = error ? 'Error' : hasLinks ? `${tagDisplayName} Links` : isEmpty ? `No ${tagDisplayName} Links` : 'Loading...';
---

<BaseLayout title={pageTitle}>
  <div class="tag-page-container">
    {/* Error State */}
    {error && (
      <ErrorState
        title={errorMessages[error].title}
        message={errorMessages[error].message}
        backLink="/"
        backLabel="← Back to Home"
      />
    )}

    {/* Empty State */}
    {isEmpty && (
      <div class="empty-state">
        <div class="empty-icon">🏷️</div>
        <h1 class="empty-title">No Links for "{tagDisplayName}"</h1>
        <p class="empty-message">
          There are no links associated with this tag yet.
        </p>
        <div class="empty-actions">
          <a href="/" class="back-link">← Browse All Links</a>
        </div>
      </div>
    )}

    {/* Success State */}
    {hasLinks && (
      <div class="success-state">
        <header class="tag-header">
          <h1 class="tag-title">
            <span class="tag-icon">🏷️</span>
            {tagDisplayName}
          </h1>
          <p class="tag-subtitle">
            {searchResponse.total_count} {searchResponse.total_count === 1 ? 'link' : 'links'} tagged with "{tagDisplayName}"
          </p>
        </header>

        <div class="links-grid">
          {searchResponse.links.map((link) => (
            <LinkCard link={link} />
          ))}
        </div>

        {/* Pagination info (for future enhancement) */}
        {searchResponse.total_pages > 1 && (
          <div class="pagination-info">
            <p>Showing page {searchResponse.page} of {searchResponse.total_pages}</p>
          </div>
        )}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  /* Main container */
  .tag-page-container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-lg);
    min-height: 60vh;
  }

  /* Common state containers */
  .error-state,
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 50vh;
  }

  /* Error state styles */
  .error-icon,
  .empty-icon {
    font-size: 3rem;
    margin-bottom: var(--space-lg);
    opacity: 0.8;
  }

  .error-title,
  .empty-title {
    font-size: 2rem;
    margin-bottom: var(--space-md);
    color: var(--color-primary);
    font-weight: 600;
  }

  .error-message,
  .empty-message {
    font-size: 1.125rem;
    color: var(--color-text);
    opacity: 0.8;
    margin-bottom: var(--space-xl);
    max-width: 500px;
    line-height: 1.6;
  }

  .error-actions,
  .empty-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    justify-content: center;
  }

  .back-link,
  .retry-button {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background-color: transparent;
    font-family: var(--font-body);
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .back-link:hover,
  .retry-button:hover {
    background-color: var(--color-footer);
    text-decoration: none;
    border-color: var(--color-primary);
  }

  .retry-button:active {
    transform: translateY(1px);
  }

  /* Success state styles */
  .success-state {
    width: 100%;
  }

  .tag-header {
    text-align: center;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .tag-title {
    font-size: 2.5rem;
    margin-bottom: var(--space-md);
    color: var(--color-primary);
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
  }

  .tag-icon {
    font-size: 2rem;
  }

  .tag-subtitle {
    font-size: 1.125rem;
    color: var(--color-text);
    opacity: 0.8;
    margin: 0;
  }

  /* Links grid */
  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  /* Pagination info */
  .pagination-info {
    text-align: center;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .pagination-info p {
    color: var(--color-text);
    opacity: 0.7;
    font-size: 0.9rem;
    margin: 0;
  }

  /* Responsive design */
  @media (max-width: 767px) {
    .tag-page-container {
      padding: var(--space-md);
    }

    .error-title,
    .empty-title {
      font-size: 1.5rem;
    }

    .error-message,
    .empty-message {
      font-size: 1rem;
    }

    .tag-title {
      font-size: 2rem;
      flex-direction: column;
      gap: var(--space-sm);
    }

    .tag-icon {
      font-size: 1.5rem;
    }

    .tag-subtitle {
      font-size: 1rem;
    }

    .links-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .error-actions,
    .empty-actions {
      flex-direction: column;
      align-items: center;
    }

    .back-link,
    .retry-button {
      width: 200px;
      text-align: center;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .links-grid {
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }
  }


  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .error-state,
    .empty-state,
    .tag-header {
      border: 2px solid var(--color-border);
    }

    .back-link,
    .retry-button {
      border-width: 2px;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .back-link,
    .retry-button {
      transition: none;
    }
  }
</style>

<script>
  // Progressive enhancement: Add search refinement (future enhancement)

  // Track page view for analytics (future enhancement)
  if (typeof window !== 'undefined') {
    const tagSlug = window.location.pathname.split('/')[2];
  }
</script>